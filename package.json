  "scripts": {
    "dev": "node --max-old-space-size=4096 node_modules/next/dist/bin/next dev",
    "dev:https": "node --max-old-space-size=4096 server.js",
    "dev:https:lan": "cross-env HOSTNAME=0.0.0.0 node --max-old-space-size=4096 server.js",
    "setup:https": "node scripts/setup-https.js",
    "setup:https:force": "node scripts/setup-https.js --force",
    "build": "tsc --noEmit -p tsconfig.build.json && node --max-old-space-size=4096 node_modules/next/dist/bin/next build",
    "start": "node server.js --production",
    "start:lan": "cross-env HOST=0.0.0.0 node server.js --production",
    "start:http": "next start",
    "lint": "next lint",
    "check": "npm run check:ui-primary && npm run check:mobile-chrome",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "benchmark:invoice-regression": "jest tests/invoice-regression.benchmark.test.ts --runInBand",
    "benchmark:invoice-golden": "jest tests/invoice-golden.benchmark.test.ts --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:migrate": "node scripts/migrate.js",
    "db:migrate:156-branch-stock": "node scripts/run-migration.js database/migrations/156_branch_item_stock_ledger_customers.sql",
    "db:migrate:157-customer-unique": "node scripts/run-migration.js database/migrations/157_customer_unique_partial.sql",
    "db:migrate:158-ledger-variant-stock": "node scripts/run-migration.js database/migrations/158_ledger_branch_variant_stock.sql",
    "db:migrate:159-deprecate-global-stock-comments": "node scripts/run-migration.js database/migrations/159_deprecate_global_stock_columns.sql",
    "db:migrate:174-closing-stock": "node scripts/run-migration.js database/migrations/174_closing_stock_management.sql",
    "db:backfill:branch-item-stock": "node scripts/backfill_branch_item_stock.js",
    "db:clear-product-tour": "node scripts/clear-product-tour.js",
    "db:fix": "node scripts/fix-schema.js",
    "db:seed": "node scripts/seed.js",
    "validate:auth": "ts-node scripts/validate-authorization-coverage.ts",
    "validate:pbac": "node scripts/validate-pbac-policies.js",
    "worker:todo": "ts-node --project tsconfig.worker.json --transpile-only -r dotenv/config lib/workers/todoReminderWorker.ts dotenv_config_path=.env.local",
    "worker:whatsapp": "ts-node --project tsconfig.worker.json --transpile-only -r tsconfig-paths/register -r dotenv/config scripts/whatsapp-message-worker.ts dotenv_config_path=.env.local",
    "aggregate:invoice-learning": "ts-node --project tsconfig.worker.json --transpile-only -r tsconfig-paths/register -r dotenv/config scripts/runInvoiceLearningAggregation.ts dotenv_config_path=.env.local",
    "worker:whatsapp:baileys": "ts-node --project tsconfig.worker.json --transpile-only -r tsconfig-paths/register -r dotenv/config scripts/whatsapp-worker.ts dotenv_config_path=.env.local",
    "test:redis": "ts-node --transpile-only scripts/test-redis-connection.ts",
    "verify:redis": "ts-node --transpile-only scripts/verify-redis-connection.ts",
    "postinstall": "patch-package",
    "pwa:icons": "node scripts/generate-pwa-icons.js",
    "puppeteer:install-chrome": "npx puppeteer browsers install chrome",
    "cap:sync": "cap sync android",
    "cap:open:android": "cap open android",
    "cap:run:android": "cap run android",
    "cap:add:android": "cap add android",
    "audit:mobile-ux": "node scripts/mobile-ux-page-audit.cjs",
    "check:ui-primary": "node scripts/check-raw-primary-ui.mjs",
    "check:mobile-chrome": "node scripts/check-mobile-page-chrome.mjs",
    "migrate:ui-primary-bg": "node scripts/migrate-primary-backgrounds.mjs",
    "migrate:ui-primary-gradients": "node scripts/migrate-primary-gradients.mjs"
  }
}
