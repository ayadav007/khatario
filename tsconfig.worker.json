{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "noEmit": false,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "ts-node": {
    "transpileOnly": true,
    "require": ["tsconfig-paths/register"],
    "compilerOptions": {
      "module": "commonjs",
      "moduleResolution": "node",
      "baseUrl": ".",
      "paths": {
        "@/*": ["./*"]
      }
    }
  },
  "include": ["lib/**/*.ts", "scripts/whatsapp-message-worker.ts", "scripts/whatsapp-worker.ts", "scripts/runInvoiceLearningAggregation.ts"],
  "exclude": ["node_modules"]
}
