datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Business {
  id                  String   @id @default(uuid()) @db.Uuid
  name                String   @db.VarChar(255)
  email               String?  @db.VarChar(255)
  phone               String?  @db.VarChar(20)
  address_line1       String?
  address_line2       String?
  city                String?  @db.VarChar(100)
  state               String?  @db.VarChar(100)
  state_code          String?  @db.VarChar(2)
  pincode             String?  @db.VarChar(10)
  gstin               String?  @db.VarChar(15)
  pan                 String?  @db.VarChar(10)
  logo_url            String?
  currency            String?  @default("INR") @db.VarChar(3)
  invoice_prefix      String?  @default("INV") @db.VarChar(10)
  next_invoice_number Int?     @default(1)
  default_tax_rate    Decimal? @default(18.00) @db.Decimal(5, 2)
  created_at          DateTime @default(now())
  updated_at          DateTime @default(now()) @updatedAt

  users                     User[]
  customers                 Customer[]
  suppliers                 Supplier[]
  categories                Category[]
  items                     Item[]
  invoices                  Invoice[]
  purchases                 Purchase[]
  payments                  Payment[]
  expenses                  Expense[]
  expense_categories        ExpenseCategory[]
  stock_movements           StockMovement[]
  whatsapp_config           WhatsAppConfig?
  whatsapp_messages         WhatsAppMessage[]
  whatsapp_reminder_settings WhatsAppReminderSetting[]
  invoice_template_settings InvoiceTemplateSetting[]
  ledger_entries            LedgerEntry[]
  offers                    Offer[]

  @@map("businesses")
}

model Offer {
  id              String   @id @default(uuid()) @db.Uuid
  business_id     String   @db.Uuid
  business        Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  type            String   @db.VarChar(50)
  condition_json  Json     @default("{}")
  action_json     Json     @default("{}")
  start_date      DateTime @db.Date
  end_date        DateTime @db.Date
  is_active       Boolean  @default(true)
  priority        Int      @default(0)
  created_at      DateTime @default(now())
  updated_at      DateTime @default(now()) @updatedAt

  @@index([business_id, is_active, start_date, end_date])
  @@index([business_id, priority])
  @@map("offers")
}

model User {
  id            String   @id @default(uuid()) @db.Uuid
  business_id   String   @db.Uuid
  business      Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  name          String   @db.VarChar(255)
  email         String?  @unique @db.VarChar(255)
  phone         String   @unique @db.VarChar(20)
  password_hash String?
  role          String?  @default("user") @db.VarChar(50)
  permissions   Json?    @default("{}")
  is_active     Boolean? @default(true)
  product_tour_completed_at DateTime? @db.Timestamptz
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  invoices_created  Invoice[]
  payments_created  Payment[]
  expenses_created  Expense[]
  stock_created     StockMovement[]

  @@map("users")
}

model Customer {
  id                   String   @id @default(uuid()) @db.Uuid
  business_id          String   @db.Uuid
  business             Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  name                 String   @db.VarChar(255)
  phone                String?  @db.VarChar(20)
  email                String?  @db.VarChar(255)
  address              String?
  city                 String?  @db.VarChar(100)
  state                String?  @db.VarChar(100)
  pincode              String?  @db.VarChar(10)
  gstin                String?  @db.VarChar(15)
  opening_balance      Decimal? @default(0) @db.Decimal(12, 2)
  opening_balance_type String?  @default("debit") @db.VarChar(10)
  credit_limit         Decimal? @default(0) @db.Decimal(12, 2)
  tags                 String[]
  notes                String?
  is_active            Boolean? @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt

  invoices Invoice[]
  payments Payment[]

  @@map("customers")
}

model Supplier {
  id                   String   @id @default(uuid()) @db.Uuid
  business_id          String   @db.Uuid
  business             Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  name                 String   @db.VarChar(255)
  phone                String?  @db.VarChar(20)
  email                String?  @db.VarChar(255)
  address              String?
  city                 String?  @db.VarChar(100)
  state                String?  @db.VarChar(100)
  pincode              String?  @db.VarChar(10)
  gstin                String?  @db.VarChar(15)
  opening_balance      Decimal? @default(0) @db.Decimal(12, 2)
  opening_balance_type String?  @default("credit") @db.VarChar(10)
  is_active            Boolean? @default(true)
  created_at           DateTime @default(now())
  updated_at           DateTime @default(now()) @updatedAt

  purchases Purchase[]
  payments  Payment[]

  @@map("suppliers")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  business_id String   @db.Uuid
  business    Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  name        String   @db.VarChar(255)
  description String?
  created_at  DateTime @default(now())

  items Item[]

  @@map("categories")
}

model Item {
  id             String   @id @default(uuid()) @db.Uuid
  business_id    String   @db.Uuid
  business       Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  category_id    String?  @db.Uuid
  category       Category? @relation(fields: [category_id], references: [id])
  name           String   @db.VarChar(255)
  code           String?  @db.VarChar(100)
  barcode        String?  @db.VarChar(100)
  description    String?
  unit           String?  @default("PCS") @db.VarChar(50)
  hsn_sac        String?  @db.VarChar(10)
  purchase_price Decimal? @default(0) @db.Decimal(12, 2)
  selling_price  Decimal? @default(0) @db.Decimal(12, 2)
  mrp            Decimal? @db.Decimal(12, 2)
  tax_rate       Decimal? @default(18.00) @db.Decimal(5, 2)
  opening_stock  Decimal? @default(0) @db.Decimal(10, 2)
  current_stock  Decimal? @default(0) @db.Decimal(10, 2)
  min_stock      Decimal? @default(0) @db.Decimal(10, 2)
  image_url      String?
  is_active      Boolean? @default(true)
  is_bundle      Boolean? @default(false)
  created_at     DateTime @default(now())
  updated_at     DateTime @default(now()) @updatedAt

  stock_movements StockMovement[]
  invoice_items   InvoiceItem[]
  purchase_items  PurchaseItem[]
  bundle_rows     BundleItem[] @relation("BundleDefinition")
  bundle_in       BundleItem[] @relation("BundleComponentItem")

  @@map("items")
}

model BundleItem {
  id        String   @id @default(uuid()) @db.Uuid
  bundle_id String   @db.Uuid
  bundle    Item     @relation("BundleDefinition", fields: [bundle_id], references: [id], onDelete: Cascade)
  item_id   String   @db.Uuid
  item      Item     @relation("BundleComponentItem", fields: [item_id], references: [id], onDelete: Restrict)
  quantity  Decimal  @db.Decimal(18, 6)

  @@unique([bundle_id, item_id])
  @@map("bundle_items")
}

model Invoice {
  id                         String   @id @default(uuid()) @db.Uuid
  business_id                String   @db.Uuid
  business                   Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  customer_id                String?  @db.Uuid
  customer                   Customer? @relation(fields: [customer_id], references: [id])
  invoice_number             String   @db.VarChar(100)
  invoice_date               DateTime @db.Date
  due_date                   DateTime? @db.Date
  status                     String?  @default("draft") @db.VarChar(20)
  payment_status             String?  @default("unpaid") @db.VarChar(20)
  place_of_supply_state_code String?  @db.VarChar(2)
  is_reverse_charge          Boolean? @default(false)
  
  subtotal           Decimal? @default(0) @db.Decimal(12, 2)
  discount_total     Decimal? @default(0) @db.Decimal(12, 2)
  additional_charges Decimal? @default(0) @db.Decimal(12, 2)
  tax_total          Decimal? @default(0) @db.Decimal(12, 2)
  round_off          Decimal? @default(0) @db.Decimal(12, 2)
  grand_total        Decimal? @default(0) @db.Decimal(12, 2)
  paid_amount        Decimal? @default(0) @db.Decimal(12, 2)
  balance_amount     Decimal? @default(0) @db.Decimal(12, 2)
  
  notes             String?
  terms             String?
  template_id       String?  @db.VarChar(100)
  template_settings Json?
  created_at        DateTime @default(now())
  updated_at        DateTime @default(now()) @updatedAt
  created_by        String?  @db.Uuid
  creator           User?    @relation(fields: [created_by], references: [id])

  items InvoiceItem[]

  @@unique([business_id, invoice_number])
  @@map("invoices")
}

model InvoiceItem {
  id               String   @id @default(uuid()) @db.Uuid
  invoice_id       String   @db.Uuid
  invoice          Invoice  @relation(fields: [invoice_id], references: [id], onDelete: Cascade)
  item_id          String?  @db.Uuid
  item             Item?    @relation(fields: [item_id], references: [id])
  item_name        String   @db.VarChar(255)
  description      String?
  hsn_sac          String?  @db.VarChar(10)
  quantity         Decimal  @db.Decimal(10, 2)
  unit             String?  @db.VarChar(50)
  unit_price       Decimal  @db.Decimal(12, 2)
  discount_percent Decimal? @default(0) @db.Decimal(5, 2)
  discount_amount  Decimal? @default(0) @db.Decimal(12, 2)
  tax_rate         Decimal? @default(0) @db.Decimal(5, 2)
  tax_amount       Decimal? @default(0) @db.Decimal(12, 2)
  line_total       Decimal  @db.Decimal(12, 2)
  sort_order       Int?     @default(0)

  @@map("invoice_items")
}

model Payment {
  id             String   @id @default(uuid()) @db.Uuid
  business_id    String   @db.Uuid
  business       Business @relation(fields: [business_id], references: [id], onDelete: Cascade)
  type           String   @db.VarChar(20) // receivable/payable
  customer_id    String?  @db.Uuid
  customer       Customer? @relation(fields: [customer_id], references: [id])
  supplier_id    String?  @db.Uuid
  supplier       Supplier? @relation(fields: [supplier_id], references: [id])
  reference_type String?  @db.VarChar(50)
  reference_id   String?  @db.Uuid
  amount         Decimal  @db.Decimal(12, 2)
  payment_mode   String?  @db.VarChar(50)
  payment_date   DateTime @db.Date
  notes          String?
  created_at     DateTime @default(now())
  created_by     String?  @db.Uuid
  creator        User?    @relation(fields: [created_by], references: [id])

  @@map("payments")
}

// Additional models omitted for brevity but would follow the same pattern
// Purchases, Expenses, Ledger, WhatsApp tables...

