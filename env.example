# ===========================================
# DATABASE CONFIGURATION (REQUIRED)
# ===========================================
# Replace these values with your PostgreSQL credentials
DB_HOST=localhost
DB_PORT=5432
DB_NAME=khatario
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# Deploy / migrations only (postgres superuser). App runtime keeps using DB_USER above.
# MIGRATION_DATABASE_URL=postgresql://postgres:your_postgres_password@127.0.0.1:5432/khatario

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Playwright full-journey E2E: set to true when reusing `npm run dev` (not started by Playwright)
# so repeated signups from the same IP are not rate-limited.
# E2E_DISABLE_RATE_LIMIT=true

# ===========================================
# WHATSAPP CONFIGURATION (Optional)
# ===========================================
# Uncomment and fill in if using WhatsApp Cloud API
# WHATSAPP_CLOUD_API_KEY=
# WHATSAPP_CLOUD_API_SECRET=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_SESSION_PATH=./whatsapp-sessions

# ===========================================
# GROQ API (Optional - for HSN/SAC validation)
# ===========================================
# Get free API key from: https://console.groq.com/keys
# Free tier: 14,400 requests/day
# GROQ_API_KEY=

# ===========================================
# REDIS CONFIGURATION (For Todo Reminders)
# ===========================================
REDIS_URL=redis://localhost:6379

# ===========================================
# AUTHENTICATION (For Future Implementation)
# ===========================================
# JWT_SECRET=generate_a_random_string_here
# NEXTAUTH_SECRET=another_random_string
# NEXTAUTH_URL=http://localhost:3000

